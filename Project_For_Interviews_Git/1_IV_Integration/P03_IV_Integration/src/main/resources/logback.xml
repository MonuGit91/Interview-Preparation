<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<!-- Rolling File Appender to write logs to a file -->
	<appender name="FILE"
		class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>logs/app.log</file>
		<rollingPolicy
			class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>logs/app-%d{yyyy-MM-dd}.log</fileNamePattern>
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<encoder>
			<!-- <pattern>%d{yyyy-MM-dd HH:mm:ss} : [%-55.55class] : %-4L : %-5level - %msg%n</pattern> -->
			<pattern>%d{yyyy-MM-dd HH:mm:ss} : [%-55.55class] : %-4L : %-6level : [%t] - %msg%n</pattern>
			<!-- <pattern>%msg%n</pattern> -->
		</encoder>
	</appender>

	<!-- Console Appender to log to the console as well -->
	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<!-- <pattern>%d{yyyy-MM-dd HH:mm:ss} : [%-55.55class] : %-4L : %-5level - %msg%n</pattern> -->
			<pattern>%d{yyyy-MM-dd HH:mm:ss} : [%-55.55class] : %-4L : %-6level : [%-12t] - %msg%n</pattern>
			<!-- <pattern>%msg%n</pattern> -->
		</encoder>
	</appender>

	<!-- Root Logger Configuration -->
	<root level="INFO">  <!-- TRACE < DEBUG < INFO < WARN < ERROR -->
		<appender-ref ref="FILE" />
		<appender-ref ref="CONSOLE" />
	</root>
</configuration>
